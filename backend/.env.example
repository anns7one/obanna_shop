# Copy to .env and fill in real values for local/dev use. Never commit the real .env.

DATABASE_URL=postgresql+asyncpg://obanna:obanna@localhost:5432/obanna
TEST_DATABASE_URL=postgresql+asyncpg://obanna:obanna@localhost:5432/obanna_test
REDIS_URL=redis://localhost:6379/0

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-to-a-random-64-byte-urlsafe-string

ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30

CORS_ORIGINS=http://localhost:3000

ENVIRONMENT=development
